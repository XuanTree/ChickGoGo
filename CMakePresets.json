{
    "version": 8,
    "configurePresets": [
        {
            "name": "GCC 15.2.0 x86_64-w64-mingw32",
            "displayName": "GCC 15.2.0",
            "description": "正在使用编译器: C = D:\\MinGW64\\bin\\gcc.exe, CXX = D:\\MinGW64\\bin\\g++.exe",
            "generator": "MinGW Makefiles",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "cacheVariables": {
            "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/${presetName}",
            "CMAKE_C_COMPILER": "D:/MinGW64/bin/gcc.exe",
            "CMAKE_CXX_COMPILER": "D:/MinGW64/bin/g++.exe",
            "CMAKE_BUILD_TYPE": "Debug"
          },
          "vendor": {
            "microsoft.com/VisualStudioSettings/CMake/1.0": {
              "intelliSenseMode": "windows-clang-x64",
              "intelliSenseOptions": {
                "useCompilerDefaults": true,
                "additionalCompilerArgs": [
                  "-std=c++17",
                  "-isystem",
                  "D:/SFML64/include"
                ]
              }
            }
          }
        }
    ]
}
